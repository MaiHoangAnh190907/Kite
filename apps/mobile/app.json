{
  "expo": {
    "name": "Kite",
    "slug": "kite",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "kite",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#87CEEB"
    },
    "ios": {
      "supportsTablet": true,
      "isTabletOnly": true,
      "bundleIdentifier": "com.kitehealth.app",
      "requireFullScreen": true
    },
    "extra": {
      "apiBaseUrl": "http://10.136.41.217:3000/api/v1"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
